# ── overview.js: form ─────────────────────────

msgid "EasyMesh Configuration"
msgstr "EasyMesh 配置"

msgid "Wireless mesh network based on batman-adv + 802.11s."
msgstr "基于 batman-adv + 802.11s 的无线 Mesh 网络。"

msgid "Basic Settings"
msgstr "基本设置"

msgid "Enable EasyMesh"
msgstr "启用 EasyMesh"

msgid "Node Role"
msgstr "节点角色"

msgid "Master handles DHCP and uplink. Agent extends coverage as a slave node."
msgstr "主节点负责 DHCP 和上行；Agent 从节点负责覆盖延伸。"

msgid "Master (connected to modem/ISP)"
msgstr "主节点（连接光猫/ISP）"

msgid "Agent (Slave, extends coverage)"
msgstr "从节点 Agent（扩展覆盖范围）"

msgid "Backhaul Type"
msgstr "回程方式"

msgid "Wired is more stable. Wireless uses a dedicated 5 GHz band."
msgstr "有线回程更稳定；无线回程使用独立 5GHz 频段。"

msgid "Wired (recommended)"
msgstr "有线回程（推荐）"

msgid "Wireless (5 GHz)"
msgstr "无线回程（5GHz）"

msgid "Auto (wired preferred)"
msgstr "自动选择（有线优先）"

msgid "Mesh Backhaul"
msgstr "Mesh 回程网络"

msgid "Internal wireless link between nodes, invisible to clients."
msgstr "节点间内部无线链路，对客户端不可见。"

msgid "Mesh Settings"
msgstr "Mesh 设置"

msgid "Advanced"
msgstr "高级"

msgid "Mesh Network ID"
msgstr "Mesh 网络 ID"

msgid "Must be identical on all nodes"
msgstr "所有节点必须完全一致"

msgid "Mesh Password (SAE)"
msgstr "Mesh 密码（SAE 加密）"

msgid "Must be identical on all nodes. Leave empty to disable encryption (not recommended)."
msgstr "所有节点必须完全一致。留空则不加密（不推荐）。"

msgid "Minimum 8 characters"
msgstr "至少 8 位字符"

msgid "Mesh Backhaul Band"
msgstr "Mesh 回程频段"

msgid "2.4 GHz (better range, slower)"
msgstr "2.4GHz（穿墙好，速度慢）"

msgid "5 GHz (faster, recommended)"
msgstr "5GHz（速度快，推荐）"

msgid "batman-adv Routing Algorithm"
msgstr "batman-adv 路由算法"

msgid "(default, best compatibility)"
msgstr "（默认，兼容性最好）"

msgid "(more accurate, requires kernel support)"
msgstr "（更精确，需要内核支持）"

msgid "802.11s Native Forwarding"
msgstr "802.11s 原生转发"

msgid "Normally disabled — batman-adv handles forwarding."
msgstr "通常关闭，转发由 batman-adv 负责。"

msgid "Client WiFi (AP)"
msgstr "客户端 WiFi（AP）"

msgid "SSID visible to phones and laptops. Must be identical on all nodes for seamless roaming."
msgstr "手机和电脑看到的 WiFi 名称，所有节点必须一致才能无缝漫游。"

msgid "WiFi Name (SSID)"
msgstr "WiFi 名称（SSID）"

msgid "WiFi Password"
msgstr "WiFi 密码"

msgid "WPA2/WPA3. Leave empty for open network."
msgstr "WPA2/WPA3 加密，留空为开放网络。"

msgid "Roaming (802.11r/k/v)"
msgstr "漫游设置（802.11r/k/v）"

msgid "Helps devices switch nodes quickly. Requires open-source mac80211 driver support."
msgstr "帮助设备快速切换节点，需要开源 mac80211 驱动支持。"

msgid "Fast Roaming"
msgstr "快速漫游"

msgid "802.11r Fast BSS Transition"
msgstr "802.11r 快速 BSS 切换"

msgid "Greatly reduces disconnect time when switching nodes. Recommended."
msgstr "大幅减少节点切换时的断线时间，推荐开启。"

msgid "Mobility Domain ID"
msgstr "漫游域 ID"

msgid "4-digit hex string. Must be identical on all nodes."
msgstr "4 位十六进制字符串，所有节点必须一致。"

msgid "802.11k Neighbor Report"
msgstr "802.11k 邻居报告"

msgid "Informs devices about nearby nodes to assist proactive roaming."
msgstr "向设备通报附近节点，辅助主动漫游。"

msgid "802.11v BSS Transition Management"
msgstr "802.11v BSS 过渡管理"

msgid "Actively steers weak-signal devices to a better node."
msgstr "主动引导信号弱的设备切换到更好的节点。"

msgid "Pre-negotiate keys over wired backbone for faster transition. Disable if issues occur."
msgstr "通过有线骨干预协商密钥，切换更快。如遇问题可关闭。"

msgid "Reassociation Deadline (ms)"
msgstr "重关联超时（毫秒）"

