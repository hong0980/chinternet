msgid ""
msgstr ""
"Content-Type: text/plain; charset=UTF-8\n"

msgid "AP + Mesh Deployment"
msgstr "AP + Mesh 部署"

msgid "Mesh Backhaul"
msgstr "Mesh 回程"

msgid "Mesh11sd Daemon"
msgstr "Mesh11sd 守护进程"

msgid "Miscellaneous"
msgstr "杂项"

msgid "Network Mode"
msgstr "网络模式"

msgid "Select a preset to auto-fill WAN and LAN settings below; choose Custom to configure manually"
msgstr "选择预设模式自动填充下方 WAN/LAN 设置；选择「自定义」可手动配置"

msgid "WAN Protocol"
msgstr "WAN 协议"

msgid "Bridge to LAN"
msgstr "桥接至 LAN"

msgid "DHCP client"
msgstr "DHCP 客户端"

msgid "PPPoE Username"
msgstr "PPPoE 用户名"

msgid "PPPoE Password"
msgstr "PPPoE 密码"

msgid "LAN Mode"
msgstr "LAN 模式"

msgid "DHCP: node gets IP from upstream router (local DHCP server disabled). Static: fixed IP on LAN bridge (local DHCP server disabled)."
msgstr "DHCP：节点从上游路由器获取 IP（禁用本地 DHCP 服务）。静态：LAN 桥使用固定 IP（禁用本地 DHCP 服务）。"

msgid "Static address"
msgstr "静态地址"

msgid "Default"
msgstr "默认"

msgid "Node Static IP"
msgstr "节点静态 IP"

msgid "Static IPv4 address for this node's LAN bridge. Must be unique per node, e.g. 192.168.2.2 / .3 / .4"
msgstr "本节点 LAN 桥的静态 IPv4 地址，每个节点必须唯一，例如 192.168.2.2 / .3 / .4"

msgid "Gateway / DNS"
msgstr "网关 / DNS"

msgid "Upstream router IP, used as the default gateway and DNS server for this node"
msgstr "上游路由器 IP，用作本节点的默认网关和 DNS 服务器"

msgid "DHCP Assigned IP"
msgstr "DHCP 分配的 IP"

msgid "IP address assigned to this node by the upstream DHCP server; shown for reference only"
msgstr "由上游 DHCP 服务器分配给本节点的 IP 地址，仅供参考"

msgid "Dual-band Merge"
msgstr "双频合一"

msgid "Enabled: one SSID/password applied to both 2.4 GHz and 5 GHz radios. Disabled: set different SSID and password for each band."
msgstr "启用后，2.4 GHz 和 5 GHz 共用同一 SSID 和密码。禁用后，可为每个频段单独设置。"

msgid "Enable usteer Smart Steering"
msgstr "启用 usteer 智能频段导向"

msgid "Uses usteer to steer clients to the best radio for optimal performance."
msgstr "使用 usteer 将客户端引导至最佳无线频段以获得最优性能。"

msgid "Must exactly match the main router SSID to enable seamless roaming"
msgstr "所有路由器 SSID 完全一致，以实现无缝漫游"

msgid "2.4 GHz WiFi Password"
msgstr "2.4 GHz WiFi 密码"

msgid "Encryption: psk2+ccmp (WPA2). Minimum 8 characters."
msgstr "加密方式：psk2+ccmp（WPA2），最少 8 个字符。"

msgid "5 GHz WiFi Password"
msgstr "5 GHz WiFi 密码"

msgid "Shared by 2.4 GHz and 5 GHz"
msgstr "2.4 GHz 和 5 GHz 共用"

msgid "WiFi Password"
msgstr "WiFi 密码"

msgid "Shared by 2.4 GHz and 5 GHz; minimum 8 characters"
msgstr "2.4 GHz 和 5 GHz 共用；最少 8 个字符"

msgid "Mesh Backhaul Band"
msgstr "Mesh 回程频段"

msgid "Select the radio band used for the 802.11s mesh backhaul link."
msgstr "选择用于 802.11s Mesh 回程链路的无线频段。"

msgid "5 GHz (recommended, best throughput)"
msgstr "5 GHz（推荐，吞吐量最高）"

msgid "2.4 GHz (longer range, lower throughput)"
msgstr "2.4 GHz（覆盖范围更广，吞吐量较低）"

msgid "All bands (all radios participate in the mesh)"
msgstr "全频段（所有无线频段均参与 Mesh）"

msgid "Must be identical on every mesh node"
msgstr "所有 Mesh 节点必须完全一致"

msgid "Mesh Password"
msgstr "Mesh 密码"

msgid "SAE (WPA3) passphrase; minimum 8 characters, must match on all nodes"
msgstr "SAE（WPA3）密码短语；最少 8 个字符，所有节点必须一致"

msgid "Mesh Status"
msgstr "Mesh 状态"

msgid "View Mesh Status"
msgstr "查看 Mesh 状态"

msgid "Checking Mesh status..."
msgstr "正在检查 Mesh 状态..."

msgid "No active mesh interface found."
msgstr "未找到活跃的 Mesh 接口。"

msgid "(No neighbor nodes connected)"
msgstr "（当前无邻居节点连接）"

msgid "(No mesh paths established)"
msgstr "（尚未建立 Mesh 转发路径）"

msgid "Mesh Interface"
msgstr "Mesh 接口"

msgid "FORWARDING PATH DUMP (mpath)"
msgstr "转发路径信息（mpath）"

msgid "Execution failed: %s"
msgstr "执行失败：%s"

msgid "Daemon Status"
msgstr "守护进程状态"

msgid "Running"
msgstr "运行中"

msgid "Stopped"
msgstr "未运行"

msgid "When enabled, the daemon continuously monitors mesh interfaces, synchronises kernel parameters, removes phantom routes, and manages DHCP role selection based on upstream connectivity."
msgstr "启用后，守护进程持续监控 Mesh 接口、同步内核参数、清除幽灵路由条目，并根据上游连通性自动管理 DHCP 角色。"

msgid "Enable mesh11sd Daemon"
msgstr "启用 mesh11sd"

msgid "Log Level"
msgstr "日志级别"

msgid "Sets the debug log level."
msgstr "设置守护进程的调试日志等级。"

msgid "Silent"
msgstr "静默"

msgid "Notification"
msgstr "通知"

msgid "Info"
msgstr "信息"

msgid "Debug"
msgstr "调试"

msgid "Check Interval (seconds)"
msgstr "巡检间隔（秒）"

msgid "How often the daemon checks and updates mesh configuration. Minimum: 10."
msgstr "守护进程检查并更新 Mesh 配置的频率（秒）。最小 10 秒。"

msgid "Interface Timeout (seconds)"
msgstr "接口超时（秒）"

msgid "Time to wait for a mesh interface to become ready before giving up."
msgstr "等待 Mesh 接口就绪的超时时间（秒）。超时后放弃本轮尝试。"

msgid "Mesh Path Cost"
msgstr "Mesh 路径成本"

msgid "STP cost assigned to the mesh network. Range: 0–65534. Set to 0 to disable STP."
msgstr "分配给 Mesh 网络的 STP 路径成本。范围 0–65534，设为 0 禁用 STP。"

msgid "Auto Configuration"
msgstr "自动配置"

msgid ""
"Enables autonomous dynamic mesh configuration.<br>"
"<span style=\"color: #d63638; font-weight: bold;\">⚠️ Warning:"
" If an existing mesh configuration is found, it will be honoured even if it is incorrect.<br>"
"Manually configuring a mesh can soft brick the router if incorrectly done.<br></span>"
"Auto config can be tested using the command line function: <code>mesh11sd auto_config test</code>"
msgstr ""
"启用自主动态 Mesh 配置。<br>"
"<span style=\"color: #d63638; font-weight: bold;\">⚠️ 警告:"
" 如果发现现有的 Mesh 配置，即使不正确也会被使用。<br>"
"手动配置 Mesh 如果操作不当，可能导致路由器软砖。<br></span>"
"可以使用命令行功能测试自动配置：<code>mesh11sd auto_config test</code>"

msgid "Disabled"
msgstr "禁用"

msgid "Enabled"
msgstr "启用"

msgid "Portal Detection Mode"
msgstr "门户节点检测模式"

msgid "Controls how this node determines its role in the mesh.<br>Force routed portal (MRP): always acts as IPv4 NAT gateway regardless of upstream.<br>Auto detect (default): portal if upstream WAN is active, otherwise layer-2 bridge peer.<br>CPE mode: treats mesh backhaul as upstream WAN; creates its own NAT subnet. Forces VXLAN tunnel off.<br>Bridge VXLAN trunk portal (MBP): bridged (no-NAT) portal; adds WAN port to vxtunnel bridge.<br>Bridge VXLAN trunk peer (TPN): peer node; adds WAN port to vxtunnel bridge."
msgstr "控制此节点如何确定其在网状网络中的角色。<br>强制路由门户 (MRP)：无论上游如何，始终充当 IPv4 NAT 网关。<br>自动检测（默认）：如果上游 WAN 活跃则为门户，否则为二层桥接对等节点。<br>CPE 模式：将网状回程视为上游 WAN；创建自己的 NAT 子网。强制关闭 VXLAN 隧道。<br>桥接 VXLAN 干线门户 (MBP)：桥接（无 NAT）门户；将 WAN 端口添加到 vxtunnel 桥。<br>桥接 VXLAN 干线对等节点 (TPN)：对等节点；将 WAN 端口添加到 vxtunnel 桥。"

msgid "Forced Routed Portal (MRP)"
msgstr "强制路由门户（MRP）"

msgid "Auto Detect (default)"
msgstr "自动检测（默认）"

msgid "Client Premises Equipment (CPE)"
msgstr "客户前端设备（CPE）"

msgid "Bridge VXLAN Trunk Portal (MBP)"
msgstr "桥接 VXLAN 主干门户（MBP）"

msgid "Bridge VXLAN Trunk Peer (TPN)"
msgstr "桥接 VXLAN 主干 Peer（TPN）"

msgid "Portal Channel (2.4 GHz)"
msgstr "门户信道（2.4 GHz）"

msgid "Forced portal channel for the 2.4 GHz band. All peer nodes will autonomously track this channel. or a valid channel number 1–13."
msgstr "强制指定门户使用的 2.4 GHz 信道，所有 Peer 节点会自动跟踪此信道。可选有效信道编号 1–13。"

msgid "Auto-select"
msgstr "自动选择"

msgid "Use Default IPv4"
msgstr "使用默认 IPv4"

msgid "Only effective when this node is a portal. When enabled, the IPv4 address from /etc/config/network is used as the portal address. When disabled, an address is auto-calculated from the label MAC address."
msgstr "仅当本节点为门户时有效。启用后使用 network 中的 IPv4 地址作为门户地址；禁用时基于标签 MAC 地址计算一个 IP 子网地址。"

msgid "Portal Detect Threshold"
msgstr "门户检测看门狗阈值"

msgid "Number of consecutive check intervals without portal contact before the watchdog takes action (attempts reconnection, then reboots). Set to 0 to disable the watchdog."
msgstr "连续多少个巡检周期未与门户通信后触发看门狗（先尝试重连，仍失败则重启节点）。设为 0 禁用看门狗。"

msgid "Channel Tracking Checkinterval (seconds)"
msgstr "信道跟踪间隔（秒）"

msgid "Minimum interval after which peer nodes begin tracking the portal channel. Values smaller than Check Interval are ignored."
msgstr "对等节点开始信道跟踪的最小间隔（秒）。小于巡检间隔的值将被忽略。"

msgid "Auto Mesh ID"
msgstr "自动 Mesh ID"

msgid "A string that is hashed to produce a secure mesh ID. Must be identical on every mesh node. Only used when Auto Configuration is enabled."
msgstr "该字符串经哈希后生成安全的 Mesh ID。所有节点必须完全一致。"

msgid "Auto Mesh Band"
msgstr "自动 Mesh 频段"

msgid "Radio band to use for the auto-configured mesh interface. All peer nodes will autonomously track the portal channel regardless of this setting. Must be identical on every mesh node."
msgstr "自动配置 Mesh 接口所使用的无线频段。所有 Peer 节点会自动跟踪门户信道，与此设置无关。所有节点必须一致。"

msgid "Auto Mesh Key"
msgstr "自动 Mesh 密钥"

msgid "A string used to generate a secure SHA-256 mesh encryption key. Must be identical on every mesh node when Auto Configuration is enabled."
msgstr "用于生成安全 SHA-256 Mesh 加密密钥的字符串。启用自动配置时所有节点必须一致。"

msgid "Mesh PHY Index"
msgstr "Mesh PHY 索引"

msgid "Force the auto-config mesh interface onto a specific radio (e.g. 0 for phy0, 1 for phy1). Useful on devices with multiple radios on the same band. Default: not set (first matching phy used)."
msgstr "强制自动配置 Mesh 接口使用指定的无线硬件（如 0 对应 phy0、1 对应 phy1）。适用于同频段有多个硬件的设备。默认不设置（使用第一个匹配的 phy）。"

msgid "Country Code"
msgstr "国家代码"

msgid "Set a valid ISO country code for all radios (e.g. US, CN, DE). Overrides the country set in the wireless config. Defaults to DFS-ETSI if not set."
msgstr "为所有无线频段设置有效的 ISO 国家代码（如 US、CN、DE），将覆盖无线配置中的国家设置。未设置时默认使用 DFS-ETSI。"

msgid "Mesh Basename"
msgstr "Mesh 基础名称"

msgid "String used to construct the mesh interface name in the form m-xxxx-n. Non-alphanumeric characters are removed; only the first 4 characters are used. Default: 11s (produces interface name m-11s-0)."
msgstr "用于构造 Mesh 接口名称（格式 m-xxxx-n）。非字母数字字符会被去除，仅取前 4 个字符。默认 11s，生成接口名 m-11s-0。"

msgid "Mesh Gate Base SSID"
msgstr "Mesh Gate 基础 SSID"

msgid "Base SSID string for this node's gate (access point). Maximum 30 characters (or 22 if SSID Suffix is enabled). Overrides the SSID in the wireless config. Default: uses wireless config SSID."
msgstr "本节点 Gate（接入点）的基础 SSID。最多 30 个字符（启用 SSID 后缀时最多 22 个），将覆盖无线配置中的 SSID。默认使用无线配置中的 SSID。"

msgid "Mesh Gate Encryption"
msgstr "Mesh Gate 加密方式"

msgid "Encryption mode for this node's gate (access point)."
msgstr "本节点 Gate（接入点）的加密方式。"

msgid "None / OWE-transition"
msgstr "无加密 / OWE 过渡"

msgid "SAE-mixed (WPA2/WPA3)"
msgstr "SAE 混合（WPA2/WPA3）"

msgid "PSK2 (WPA2)"
msgstr "PSK2（WPA2）"

msgid "Opportunistic Wireless Encryption (OWE)"
msgstr "机会无线加密（OWE）"

msgid "Mesh Gate Key"
msgstr "Mesh Gate 密钥"

msgid "Encryption key for this node's gate. Ignored when Mesh Gate Encryption is set to 0 (none) or 4 (OWE). Minimum 8 characters."
msgstr "本节点 Gate 的加密密钥。Mesh Gate 加密设为 0（无加密）或 4（OWE）时忽略。最少 8 个字符。"

msgid "SSID Suffix Enable"
msgstr "启用 SSID 后缀"

msgid "Append a 4-digit suffix (last 4 hex digits of the mesh interface MAC address) to the SSID. When enabled, limits Gate Base SSID to 22 characters."
msgstr "在 SSID 末尾追加 4 位十六进制后缀（Mesh 接口 MAC 地址的最后 4 位）。启用后 Gate 基础 SSID 长度限制为 22 个字符。"

msgid "VXLAN Tunnel Enable"
msgstr "启用 VXLAN 隧道"

msgid "Enables point-to-multipoint VXLAN tunneling from the portal to all compatible peer nodes. Forced to 0 when Portal Detection Mode is set to 3 (CPE)."
msgstr "启用从门户节点到所有兼容 Peer 节点的点对多点 VXLAN 隧道。门户节点检测模式设为 3（CPE）时强制关闭。"

msgid "Tunnel ID"
msgstr "隧道 ID"

msgid "VXLAN tunnel identifier. A decimal number between 1 and 16777216 (24-bit)."
msgstr "VXLAN 隧道标识符，十进制数，范围 1–16777216（24 位）。"

msgid "VXLAN Tunnel IPv4 Gateway"
msgstr "VXLAN 隧道 IPv4 网关"

msgid "IPv4 gateway address for the VXLAN tunnel subnet. Becomes active when this node is a portal (Portal Detection Mode 0 or 1)."
msgstr "VXLAN 隧道子网的 IPv4 网关地址。本节点成为门户时生效（门户检测模式 0 或 1）。"

msgid "VXLAN Tunnel IPv4 Mask"
msgstr "VXLAN 隧道 IPv4 掩码"

msgid "Subnet mask for the VXLAN tunnel address."
msgstr "VXLAN 隧道地址的子网掩码。"

msgid "VXLAN Tunnel Gate Encryption"
msgstr "VXLAN 隧道 Gate 加密"

msgid "Encryption mode for access points connected to the VXLAN tunnel."
msgstr "连接至 VXLAN 隧道的接入点的加密方式。"

msgid "VXLAN Tunnel Gate Key"
msgstr "VXLAN 隧道 Gate 密钥"

msgid "Encryption key for VXLAN tunnel gate access points. Ignored when Tunnel Gate Encryption is 0 or 4. Minimum 8 characters."
msgstr "VXLAN 隧道 Gate 接入点的加密密钥。隧道 Gate 加密设为 0 或 4 时忽略。最少 8 个字符。"

msgid "VXLAN Tunnel Base SSID"
msgstr "VXLAN 隧道基础 SSID"

msgid "Base SSID for access points connected to the VXLAN tunnel. Maximum 30 characters (or 22 if SSID Suffix is enabled)."
msgstr "连接至 VXLAN 隧道的接入点基础 SSID。最多 30 个字符（启用 SSID 后缀时最多 22 个）。默认 Guest。"

msgid "VXLAN Tunnel Path Cost"
msgstr "VXLAN 隧道路径成本"

msgid "STP cost assigned to the VXLAN tunnel network. Range: 0–65534. Set to 0 to disable STP."
msgstr "分配给 VXLAN 隧道网络的 STP 路径成本。范围 0–65534，设为 0 禁用 STP。"

msgid "Mesh Gate Enable"
msgstr "Mesh Gate 启用模式"

msgid "Controls whether this node provides a gate (access point) into the mesh."
msgstr "控制本节点是否提供 Gate 接入点进入 Mesh 网络。"

msgid "Disable all mesh gate access points"
msgstr "禁用所有 Mesh Gate 接入点"

msgid "Enable all mesh gate access points"
msgstr "启用所有 Mesh Gate 接入点"

msgid "Enable only on radios NOT shared with mesh interface"
msgstr "仅在未与 Mesh 接口共用无线频段的频段上启用"

msgid "Leech Mode Enable"
msgstr "启用 Leech 模式"

msgid ""
"When enabled, this node acts as an AP with mesh backhaul but does NOT contribute to mesh routing/forwarding.<br>"
"Useful when a node is within coverage of 2 or more peers and would otherwise create unstable multi-hop paths.<br>"
"Can also be toggled at runtime: <code>mesh11sd mesh_leechmode [enable/disable]</code>."
msgstr ""
"启用后，本节点仅作为接入点提供客户端无线接入，不参与 Mesh 路由转发。<br>"
"适用于处于多个 Peer 节点覆盖范围内、可能造成不稳定多跳路径的节点。<br>"
"也可通过命令行实时切换：<code>mesh11sd mesh_leechmode [enable/disable]</code>。"

msgid "TX Power (dBm)"
msgstr "发射功率（dBm）"

msgid "Transmit power for the mesh radio in dBm. Values outside the regulatory domain limits are ignored. Default: driver/wireless config default."
msgstr "Mesh 无线频段的发射功率（dBm）。超出监管域限制的值将被忽略。默认使用驱动或无线配置中的默认值。"

msgid "Mesh Path Stabilisation"
msgstr "Mesh 路径稳定"

msgid "Prevents frequent multi-hop path changes caused by multipath signal strength jitter."
msgstr "防止因多径信号强度抖动导致 Mesh 多跳路径频繁切换。"

msgid "Reactive Path Stabilisation Threshold"
msgstr "反应式路径稳定阈值"

msgid "Number of consecutive check intervals with an unstable neighbour path before path stabilisation is activated."
msgstr "邻居路径持续不稳定多少个连续巡检周期后激活路径稳定机制。"

msgid "MAC Forced Forwarding"
msgstr "MAC 强制转发"

msgid "Enables MAC forced forwarding on the mesh interface to prevent ARP flooding."
msgstr "在 Mesh 接口上启用 MAC 强制转发，防止 ARP 洪泛。"

msgid "Gateway Proxy ARP"
msgstr "网关代理 ARP"

msgid "Enables proxy ARP on the gateway bridge interface."
msgstr "在网关桥接接口上启用代理 ARP。"

msgid "Stop on Error"
msgstr "错误时停止"

msgid "When the watchdog detects an IPv4 communication failure with the portal, the daemon enters idle mode instead of rebooting. Useful on nodes without a reset button. Overrides Reboot on Error."
msgstr "看门狗检测到与门户 IPv4 通信失败时，守护进程进入空闲模式而非重启节点。适用于没有复位按钮的节点。优先级高于「错误时重启」。"

msgid "Reboot on Error"
msgstr "错误时重启"

msgid "When the watchdog detects a persistent IPv4 communication failure with the portal, the node is rebooted. Overridden by Stop on Error."
msgstr "看门狗检测到与门户的 IPv4 通信持续失败时重启节点。默认启用，可被「错误时停止」覆盖。"

msgid "AP Monitor Enable"
msgstr "启用 AP 监控"

msgid "Enables the access point monitoring daemon (apmond). Collects AP data and forwards it to the portal node."
msgstr "启用接入点监控守护进程（apmond），采集本节点 AP 数据并上报至门户节点。"

msgid "AP Monitor CGI Directory"
msgstr "AP 监控 CGI 目录"

msgid "Directory for apmond CGI scripts. Takes effect when this node becomes a portal. Default: /www/cgi-bin."
msgstr "apmond CGI 脚本目录，本节点成为门户时生效。默认 /www/cgi-bin。"

msgid "Mesh Backhaul LED"
msgstr "Mesh 回程 LED"

msgid "LED used as a mesh backhaul heartbeat indicator. LED is solid when the mesh interface is up, and switches to a heartbeat pattern when peers are connected. \"auto\" uses the power/system LED if present. \"none\" disables. Other LEDs are listed in /sys/class/leds as \"color:function\" (e.g. blue:run). Default: auto."
msgstr "用作 Mesh 回程心跳指示的 LED。Mesh 接口启动时常亮，有 Peer 连接时切换为心跳模式。\"auto\" 自动选择电源/系统 LED（若存在），\"none\" 禁用。其他 LED 可在 /sys/class/leds 下查看，格式为\"颜色:功能\"（如 blue:run）。默认 auto。"

msgid "RSSI Threshold (dBm)"
msgstr "RSSI 接入门限（dBm）"

msgid "Minimum signal strength required to form a peer connection. Range: −95 to −25 dBm. Default: −65. Lower values permit weaker links; higher values enforce stronger connections."
msgstr "建立 Peer 连接所需的最低信号强度。范围：−95 至 −25 dBm，默认 −65。数值越低允许信号更弱的连接；数值越高则要求更强的信号。"

msgid "Max Peer Links"
msgstr "最大 Peer 连接数"

msgid "Maximum number of simultaneous direct peer connections per node. Range: 0–32. Default: 16. Reduce on dense deployments to lower protocol overhead."
msgstr "每个节点可同时维持的最大直连 Peer 数量。范围 0–32，默认 16。节点密集时可适当降低以减少协议开销。"

msgid "Live Status"
msgstr "实时状态"

msgid "Refresh Status"
msgstr "刷新状态"

msgid "Fetching daemon status..."
msgstr "正在获取守护进程状态..."

msgid "No output. The daemon may still be starting; please retry in a moment."
msgstr "无输出。守护进程可能仍在启动中，请稍后重试。"

msgid "Daemon Log"
msgstr "守护进程日志"

msgid "View Recent Log"
msgstr "查看最近日志"

msgid "Loading log..."
msgstr "正在加载日志..."

msgid "No mesh11sd log entries found."
msgstr "未找到 mesh11sd 日志条目。"

msgid "Hostname"
msgstr "主机名"

msgid "Disabled Services"
msgstr "禁用的服务"

msgid "Services selected here will be stopped and disabled on save"
msgstr "此处勾选的服务将在保存时被停止并禁止开机自启"

msgid "Bridge + DHCP (AP/Mesh node: WAN bridged to LAN, IP assigned by upstream router)"
msgstr "桥接 + DHCP（AP/Mesh 节点：WAN 桥接至 LAN，IP 由上游路由器分配）"

msgid "Bridge + Static IP (AP/Mesh node: WAN bridged to LAN, fixed node IP)"
