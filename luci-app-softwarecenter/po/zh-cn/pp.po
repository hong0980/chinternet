msgstr "网关监控已启动"

msgid "Gateway: master %s unreachable (fail=%s/3)"
msgstr "网关监控: 主节点 %s 不可达（失败=%s/3）"

msgid "Gateway declared dead - re-electing"
msgstr "网关已失联，重新选举主节点"

msgid "Self-healing: gateway path changed -> %s (was: %s)"
msgstr "自愈: 网关路径切换 → %s（原: %s）"

msgid "Neighbor list applied: %s APs"
msgstr "邻居列表已应用: %s 个 AP"

msgid "Roam watchdog started on %s"
msgstr "漫游监控已启动，接口: %s"

msgid "SKIP: %s in cooldown (%ss)"
msgstr "跳过漫游: %s 处于冷却中（剩余 %s 秒）"

msgid "HARD steer %s (%sdBm) -> %s"
msgstr "强制引导 %s (%sdBm) → %s"

msgid "SOFT steer %s (%sdBm) -> %s"
msgstr "软引导 %s (%sdBm) → %s"

msgid "DFS watchdog started on %s"
msgstr "DFS 监控已启动，接口: %s"

msgid "DFS: mesh-wide channel change -> %s"
msgstr "DFS: 全网信道切换 → %s"

msgid "DFS: pushed channel %s to %s"
msgstr "DFS: 已推送信道 %s 至 %s"

msgid "ACS: channel %s -> %s (occupancy: %s APs)"
msgstr "ACS: 信道 %s → %s（占用: %s 个 AP）"

msgid "Dedicated backhaul: skipped (hw=%s)"
msgstr "专用回程: 已跳过（硬件类型=%s）"

msgid "Dedicated backhaul: no second 5GHz radio"
msgstr "专用回程: 未找到第二个 5GHz 无线设备"

msgid "Dedicated backhaul: %s reserved for mesh"
msgstr "专用回程: %s 已预留给 Mesh 专用"

msgid "Dedicated backhaul: removed AP %s"
msgstr "专用回程: 已移除 AP 接口 %s"

msgid "Dedicated backhaul: %s configured (ch %s, VHT80)"
msgstr "专用回程: %s 已配置（信道 %s, VHT80）"

msgid "Wireless onboard AP: %s"
msgstr "无线配网 AP: %s"

msgid "USR1: node approved — pushing profile to all approved agents"
msgstr "USR1: 节点已审批，向所有已批准从节点推送配置"

msgid "WARN USR1: no profile file, agent will get it on next poll"
msgstr "USR1 警告: 配置文件不存在，从节点将在下次轮询时获取"

msgid "USR1: pushed profile to agent %s"
msgstr "USR1: 已向从节点 %s 推送配置"

msgid "================================================"
msgstr "================================================"

msgid "EasyMesh daemon starting (pid=%s)"
msgstr "EasyMesh 守护进程启动（pid=%s）"

msgid "Hardware: %s"
msgstr "硬件类型: %s"

msgid "Starting as: %s"
msgstr "以 %s 角色启动"

msgid "DBG main: master ready, disc_server started, profile written"
msgstr "主节点就绪，发现服务已启动，配置已写入"

msgid "DBG main: agent starting find_master+register"
msgstr "从节点: 开始搜索主节点并注册"

msgid "Role switch: %s -> %s"
msgstr "角色切换: %s → %s"

msgid "DBG main_loop iter=%s: master not found yet, will retry"
msgstr "主循环第 %s 次: 主节点尚未找到，继续重试"



msgid "Agent configuration is managed by the Master"
msgstr "Agent 的配置由 Master 统一管理"

msgid "Broadcast a temporary open SSID so new nodes can join without a cable."
msgstr "广播一个临时的开放 SSID，让新节点无需网线即可加入。"

msgid "Fixed channel for dedicated backhaul radio. 149/153/157/161 recommended."
msgstr "专用回程 radio 的固定信道，推荐使用 149/153/157/161（无 DFS，80 MHz 干净）。"

msgid "Include radar-protected 5 GHz DFS channels in ACS scan."
msgstr "在 ACS 自动选频时包含受雷达保护的 5 GHz DFS 信道（52–140）。"

msgid "Live topology map. Link color = signal quality: green ≥70%, yellow ≥40%, red <40%. Hover nodes for details."
msgstr "实时拓扑图。链路颜色表示信号质量：绿色 ≥70%，黄色 ≥40%，红色 <40%。悬停节点可查看详情。"

msgid "Must be identical on all nodes. Leave empty to disable encryption."
msgstr "所有节点必须相同。留空则禁用加密（不推荐）。"

msgid "No topology data yet. Waiting for mesh to form..."
msgstr "暂无拓扑数据，等待 Mesh 网络形成……"

msgid "Pre-negotiate keys over wired backbone for faster transition."
msgstr "通过有线骨干网预协商密钥，实现更快的漫游切换。禁用可解决兼容性问题。"

msgid "Pushed to all agent nodes automatically."
msgstr "批准后自动推送到所有 Agent 节点。"

msgid "Real-time batman-adv originator table. TQ: 255 = best. Refreshes every 5 seconds."
msgstr "实时 batman-adv 邻居表。TQ：255 为最佳。每 5 秒自动刷新。"

msgid "Reserve the second 5 GHz radio exclusively for node-to-node backhaul."
msgstr "将第二块 5 GHz radio 专用于节点间回程通信，客户端不连接此 radio，保障回程带宽。"

msgid "WPA2/WPA3. Leave empty for open network. Will be pushed to all agents."
msgstr "WPA2/WPA3 加密。留空则为开放网络。批准后自动推送到所有 Agent。"

msgid "bat0 interface is not running. Check batman-adv installation (kmod-batman-adv)."
msgstr "bat0 接口未运行。请检查 batman-adv 是否已安装（kmod-batman-adv）。"

msgid "wired"
msgstr "有线"

msgid "Applied on all radios (2.4 GHz + 5 GHz). Pushed to all agent nodes automatically."
msgstr "应用于所有频段（2.4 GHz + 5 GHz）。批准后自动推送到所有 Agent 节点。"


msgid "Multi-node mesh using batman-adv routing over wired Ethernet or 802.11s wireless backhaul."
msgstr "多节点 Mesh 网络，通过有线以太网或 802.11s 无线回程运行 batman-adv 路由。"

msgid "Wired uses LAN cable between nodes (batman-adv over Ethernet). Wireless uses a dedicated 802.11s link (batman-adv over 802.11s)."
msgstr "有线模式通过 LAN 网线连接节点（batman-adv over Ethernet）；无线模式使用专用 802.11s 链路（batman-adv over 802.11s）。"

msgid "Wireless (802.11s)"
msgstr "无线（802.11s）"

msgid "Client WiFi Name (SSID)"
msgstr "客户端 WiFi 名称（SSID）"

msgid "Name of the WiFi network that phones and computers connect to. Applied on all radios (2.4 GHz + 5 GHz). Pushed to all agent nodes."
msgstr "手机和电脑连接的 WiFi 网络名称。应用于所有频段（2.4 GHz + 5 GHz），并自动推送到所有 Agent 节点。"

msgid "Client WiFi Password"
msgstr "客户端 WiFi 密码"

msgid "802.11s Mesh ID"
msgstr "802.11s Mesh 网络标识"

msgid "Network name used by the wireless mesh backhaul (802.11s). Must be identical on all nodes. Not the same as the client WiFi SSID."
msgstr "无线 Mesh 回程（802.11s）使用的网络标识，所有节点必须相同。与客户端连接的 WiFi 名称不同。"

msgid "802.11s Mesh Password (SAE)"
msgstr "802.11s Mesh 密码（SAE）"

msgid "Encryption key for the wireless mesh backhaul. Must match on all nodes. Leave empty to disable mesh encryption (not recommended on wireless backhaul)."
msgstr "无线 Mesh 回程的加密密钥，所有节点必须相同。留空则禁用 Mesh 加密（无线回程不推荐）。"

msgid "802.11s Backhaul Band"
msgstr "802.11s 回程频段"

msgid "Radio band used for the 802.11s mesh backhaul link between nodes."
msgstr "节点间 802.11s Mesh 回程链路使用的无线频段。"

msgid "Wired backhaul active"
msgstr "有线回程已启用"

msgid "batman-adv routes mesh traffic over the LAN cable between nodes. No 802.11s configuration is needed — the wireless radio is fully available for client traffic."
msgstr "batman-adv 通过节点间 LAN 网线转发 Mesh 流量。无需配置 802.11s，无线频段完全用于客户端接入。"

msgid "Enable 802.11s path selection in addition to batman-adv. Normally disabled."
msgstr "在 batman-adv 之外启用 802.11s 自身的路径选择。通常禁用，由 batman-adv 统一管理路由。"


msgid "All Wi-Fi settings (SSID, password, channel, roaming, etc.) are automatically applied according to the master node's configuration once the agent is approved. No manual configuration required."
msgstr "所有 Wi-Fi 设置（SSID、密码、信道、漫游等）在 Agent 被批准后，将自动按照主节点的配置应用，无需手动配置。"
