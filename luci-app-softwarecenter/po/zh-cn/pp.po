msgstr "添加新节点"

# ── overview.js: form ─────────────────────────

msgid "EasyMesh Configuration"
msgstr "EasyMesh 配置"

msgid "Wireless mesh network based on batman-adv + 802.11s."
msgstr "基于 batman-adv + 802.11s 的无线 Mesh 网络。"

msgid "Basic Settings"
msgstr "基本设置"

msgid "Enable EasyMesh"
msgstr "启用 EasyMesh"

msgid "Node Role"
msgstr "节点角色"

msgid "Master handles DHCP and uplink. Slave extends coverage only."
msgstr "主节点负责 DHCP 和上行；从节点仅做覆盖延伸。"

msgid "Master (connected to modem/ISP)"
msgstr "主节点（连接光猫/ISP）"

msgid "Slave (extends coverage)"
msgstr "从节点（扩展覆盖范围）"

msgid "Backhaul Type"
msgstr "回程方式"

msgid "Wired is more stable. Wireless uses a dedicated 5 GHz band."
msgstr "有线回程更稳定；无线回程使用独立 5GHz 频段。"

msgid "Wired (recommended)"
msgstr "有线回程（推荐）"

msgid "Wireless (5 GHz)"
msgstr "无线回程（5GHz）"

msgid "Auto (wired preferred)"
msgstr "自动选择（有线优先）"

msgid "Mesh Backhaul"
msgstr "Mesh 回程网络"

msgid "Internal wireless link between nodes, invisible to clients."
msgstr "节点间内部无线链路，对客户端不可见。"

msgid "Mesh Settings"
msgstr "Mesh 设置"

msgid "Advanced"
msgstr "高级"

msgid "Mesh Network ID"
msgstr "Mesh 网络 ID"

msgid "Must be identical on all nodes"
msgstr "所有节点必须完全一致"

msgid "Mesh Password (SAE)"
msgstr "Mesh 密码（SAE 加密）"

msgid "Must be identical on all nodes. Leave empty to disable encryption (not recommended)."
msgstr "所有节点必须完全一致。留空则不加密（不推荐）。"

msgid "Minimum 8 characters"
msgstr "至少 8 位字符"

msgid "Mesh Backhaul Band"
msgstr "Mesh 回程频段"

msgid "2.4 GHz (better range, slower)"
msgstr "2.4GHz（穿墙好，速度慢）"

msgid "5 GHz (faster, recommended)"
msgstr "5GHz（速度快，推荐）"

msgid "batman-adv Routing Algorithm"
msgstr "batman-adv 路由算法"

msgid "(default, best compatibility)"
msgstr "（默认，兼容性最好）"

msgid "(more accurate, requires kernel support)"
msgstr "（更精确，需要内核支持）"

msgid "802.11s Native Forwarding"
msgstr "802.11s 原生转发"

msgid "Normally disabled — batman-adv handles forwarding."
msgstr "通常关闭，转发由 batman-adv 负责。"

msgid "Client WiFi (AP)"
msgstr "客户端 WiFi（AP）"

msgid "SSID visible to phones and laptops. Must be identical on all nodes for seamless roaming."
msgstr "手机和电脑看到的 WiFi 名称，所有节点必须一致才能无缝漫游。"

msgid "WiFi Name (SSID)"
msgstr "WiFi 名称（SSID）"

msgid "WiFi Password"
msgstr "WiFi 密码"

msgid "WPA2/WPA3. Leave empty for open network."
msgstr "WPA2/WPA3 加密，留空为开放网络。"

msgid "Roaming (802.11r/k/v)"
msgstr "漫游设置（802.11r/k/v）"

msgid "Helps devices switch nodes quickly. Requires open-source mac80211 driver support."
msgstr "帮助设备快速切换节点，需要开源 mac80211 驱动支持。"

msgid "Fast Roaming"
msgstr "快速漫游"

msgid "802.11r Fast BSS Transition"
msgstr "802.11r 快速 BSS 切换"

msgid "Greatly reduces disconnect time when switching nodes. Recommended."
msgstr "大幅减少节点切换时的断线时间，推荐开启。"

msgid "Mobility Domain ID"
msgstr "漫游域 ID"

msgid "4-digit hex string. Must be identical on all nodes."
msgstr "4 位十六进制字符串，所有节点必须一致。"

msgid "802.11k Neighbor Report"
msgstr "802.11k 邻居报告"

msgid "Informs devices about nearby nodes to assist proactive roaming."
msgstr "向设备通报附近节点，辅助主动漫游。"

msgid "802.11v BSS Transition Management"
msgstr "802.11v BSS 过渡管理"

msgid "Actively steers weak-signal devices to a better node."
msgstr "主动引导信号弱的设备切换到更好的节点。"

msgid "FT over DS"
msgstr "FT over DS"

msgid "Pre-negotiate keys over wired backbone for faster transition. Disable if issues occur."
msgstr "通过有线骨干预协商密钥，切换更快。如遇问题可关闭。"

msgid "Reassociation Deadline (ms)"
msgstr "重关联超时（毫秒）"

# ── nodes.js ──────────────────────────────────

msgid "device(s) requesting to join Mesh"
msgstr "台设备申请加入 Mesh"

msgid "Approve to push config automatically. No action needed on the slave."
msgstr "确认后自动推送配置，从节点无需任何操作。"

msgid "Unknown device"
msgstr "未知设备"

msgid "Join Mesh"
msgstr "加入 Mesh"

msgid "Reject"
msgstr "拒绝"

msgid "Approved. Pushing config to slave..."
msgstr "已批准，正在向从节点推送配置…"

msgid "Mesh Status"
msgstr "Mesh 状态"

msgid "Running"
msgstr "运行中"

msgid "Not running"
msgstr "未启动"

msgid "Neighbor nodes"
msgstr "邻居节点"

msgid "found"
msgstr "台"

msgid "Mesh Neighbors"
msgstr "Mesh 邻居节点"

msgid "TQ link quality: 255 = best. Refreshes every 5 seconds."
msgstr "TQ 链路质量：255 为最佳，每 5 秒自动刷新。"

msgid "No neighbors found. Verify all nodes share the same Mesh ID and password."
msgstr "未发现邻居节点。请确认所有节点已启用 EasyMesh 且 Mesh ID/密码完全一致。"

msgid "Link Quality (TQ)"
msgstr "链路质量（TQ）"

msgid "Next Hop"
msgstr "下一跳"

msgid "Interface"
msgstr "接口"

msgid "Last Seen"
msgstr "最后在线"


msgid "Mesh Topology"
msgstr "Mesh 拓扑"

msgid "Live topology from batman-adv. Refreshes every 5 seconds."
msgstr "来自 batman-adv 的实时拓扑，每 5 秒刷新。"

msgid "Loading topology..."
msgstr "正在加载拓扑..."

msgid "Topology unavailable — master node not reachable."
msgstr "拓扑不可用 — 主节点不可达。"


msgid "Flash OpenWrt on the new node"
msgstr "在新节点上刷入 OpenWrt 固件"

msgid "Power it on and connect a LAN cable from this router to the new node"
msgstr "通电后，用网线将本路由器的 LAN 口连接到新节点"

msgid "Wait ~30 seconds — the new node auto-discovers this master, pulls config and joins the mesh"
msgstr "等待约 30 秒，新节点自动发现主节点、拉取配置并加入 Mesh"

msgid "Check the Nodes tab to confirm it appears"
msgstr "在\"节点\"页面确认新节点已出现"

msgid "No app, QR code or manual configuration needed. Wired backhaul provides the most stable mesh connection."
msgstr "无需 App、二维码或手动配置。有线回程提供最稳定的 Mesh 连接。"

msgid "Wireless Node Onboarding"
msgstr "无线添加新节点"

msgid "Broadcast a temporary open SSID so new nodes can join without a cable. Still requires approval in the Nodes tab."
msgstr "广播临时开放 SSID，让新节点无需网线即可加入。仍需在\"节点\"页面手动确认。"

msgid "Onboarding SSID"
msgstr "配网 SSID"

msgid "Leave empty to auto-generate from MAC address (e.g. EasyMesh-Setup-A1B2C3)"
msgstr "留空则自动根据 MAC 地址生成（如 EasyMesh-Setup-A1B2C3）"

msgid "Auto (EasyMesh-Setup-XXXXXX)"
msgstr "自动（EasyMesh-Setup-XXXXXX）"

msgid "Review and approve each device before it receives mesh configuration."
msgstr "在设备获取 Mesh 配置前，请逐一审核并确认。"

msgid "Approved. Node will receive config shortly."
msgstr "已批准，节点即将收到配置。"

msgid "Allow to join"
msgstr "允许加入"

msgid "Wireless"
msgstr "无线"

msgid "Wired"
msgstr "有线"

msgid "via "
msgstr "接入方式："

msgid "Advanced / Radio"
msgstr "高级 / 无线电"

msgid "Enable DFS Channels"
msgstr "启用 DFS 信道"

msgid "Include radar-protected 5 GHz DFS channels (52–140) in ACS scan. Daemon monitors for radar events and mesh-wide channel jump automatically."
msgstr "在 ACS 扫描中加入受雷达保护的 5 GHz DFS 信道（52–140）。守护进程自动监测雷达事件并全网同步跳信道。"

msgid "Dedicated Backhaul Radio (Tri-band)"
msgstr "专用回程频段（三频）"

msgid "Reserve the second 5 GHz radio exclusively for node-to-node backhaul. Clients never connect to it, preserving full backhaul bandwidth. Only effective on tri-band hardware (2.4 GHz + 5 GHz + 5 GHz)."
msgstr "将第二个 5 GHz 无线电专用于节点间回程，客户端不接入该频段，确保回程带宽不打折。仅对三频硬件有效（2.4G + 5G + 5G）。"

msgid "Backhaul Radio Band"
msgstr "回程无线频段"

msgid "Which 5 GHz radio to dedicate as backhaul (first or second)."
msgstr "指定哪个 5 GHz 无线电作为专用回程（第一或第二个）。"

msgid "Second 5 GHz radio (recommended)"
msgstr "第二个 5 GHz（推荐）"

msgid "First 5 GHz radio"
msgstr "第一个 5 GHz"

msgid "Backhaul Channel"
msgstr "回程信道"

msgid "Fixed channel for dedicated backhaul radio. 149/153/157/161 recommended (non-DFS, 80 MHz clean)."
msgstr "专用回程无线电的固定信道，推荐 149/153/157/161（非 DFS，80 MHz 无干扰）。"

msgid "Live topology. Link color = signal quality: green ≥70%, yellow ≥40%, red <40%."
msgstr "实时拓扑。连线颜色代表信号质量：绿色 ≥70%，黄色 ≥40%，红色 <40%。"

