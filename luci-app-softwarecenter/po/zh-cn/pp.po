msgstr "生成配置: ssid=%s 信道=%s"

msgid "apply_profile: missing ssid"
msgstr "应用配置失败: 缺少 ssid 字段"

msgid "Applying profile: ssid=%s channel=%s"
msgstr "正在应用配置: ssid=%s 信道=%s"

msgid "Profile applied. Joined mesh."
msgstr "配置已应用，已加入 Mesh 网络"

